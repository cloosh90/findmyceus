---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import CourseCard from '../components/CourseCard.astro';
import courses from '../data/courses.json';

// Compute stats at build time
const totalCEUs = courses.reduce((sum, c) => sum + c.ceus, 0);
const providers = [...new Set(courses.map(c => c.provider))].length;

// Featured courses (max 6)
const featured = courses.filter(c => c.featured).slice(0, 6);

// Recently added (last 6 by dateAdded, not featured)
const recent = courses
  .slice()
  .sort((a, b) => new Date(b.dateAdded).getTime() - new Date(a.dateAdded).getTime())
  .filter(c => !c.featured)
  .slice(0, 6);
---
<Layout title="FindMyCEUs — Medical Coder Continuing Education Directory">
  <Nav currentPage="home" />

  <section class="hero">
    <div class="hero-badge fu">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
      Trusted by medical coders and billers nationwide
    </div>
    <h1 class="fu d1">Find the right CEUs.<br><em>Stop searching everywhere.</em></h1>
    <p class="fu d2">The only directory built for medical coders and billers. Search AAPC and AHIMA-approved courses filtered by credential, format, specialty, and price.</p>

    <form class="search-wrap fu d3" action="/courses" method="get">
      <svg class="search-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
      <input type="text" name="q" placeholder="Search courses, topics, or providers..." autocomplete="off">
    </form>

    <div class="filters fu d4">
      <a href="/courses" class="pill active">All courses</a>
      <a href="/courses?price=free" class="pill">Free CEUs</a>
      <a href="/courses?cred=CPC" class="pill">CPC</a>
      <a href="/courses?cred=CCS" class="pill">CCS</a>
      <a href="/courses?cred=CPMA" class="pill">CPMA</a>
      <a href="/courses?fmt=On-demand" class="pill">On-demand</a>
      <a href="/courses?fmt=Live+virtual" class="pill">Live virtual</a>
      <a href="/courses?q=compliance" class="pill">Compliance</a>
    </div>

    <div class="beehiiv-wrap fu d5">
      <iframe
        src="https://subscribe-forms.beehiiv.com/cca2da0c-db8e-4fe0-b277-0a81cad4ca87"
        class="beehiiv-embed"
        data-test-id="beehiiv-embed"
        frameborder="0"
        scrolling="no"
        style="width:560px;height:291px;margin:0;border-radius:0 !important;background-color:transparent;box-shadow:none;max-width:100%;">
      </iframe>
    </div>

    <div class="stats-bar fu d5">
      <div>
        <div class="stat-num">{courses.length}</div>
        <div class="stat-label">Courses listed</div>
      </div>
      <div>
        <div class="stat-num">{providers}</div>
        <div class="stat-label">Approved providers</div>
      </div>
      <div>
        <div class="stat-num">{Math.round(totalCEUs)}+</div>
        <div class="stat-label">CEUs available</div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="section-head">
      <h2>Featured courses</h2>
      <a href="/courses">View all courses &rarr;</a>
    </div>
    <div class="grid">
      {featured.map((course) => (
        <CourseCard course={course} />
      ))}
    </div>
  </section>

  <section class="section" style="padding-top:0">
    <div class="section-head">
      <h2>Recently added</h2>
      <a href="/courses?sort=newest">See all &rarr;</a>
    </div>
    <div class="grid">
      {recent.map((course) => (
        <CourseCard course={course} />
      ))}
    </div>
  </section>

  <div class="cta-wrap" style="margin-bottom:56px">
    <div class="cta">
      <h2>Never miss a CEU deadline</h2>
      <p>Weekly digest of new courses, free CEU alerts, and renewal reminders. No spam.</p>
      <div class="beehiiv-cta-wrap">
        <iframe
          src="https://subscribe-forms.beehiiv.com/cca2da0c-db8e-4fe0-b277-0a81cad4ca87"
          class="beehiiv-embed"
          data-test-id="beehiiv-embed"
          frameborder="0"
          scrolling="no"
          style="width:560px;height:291px;margin:0 auto;display:block;border-radius:0 !important;background-color:transparent;box-shadow:none;max-width:100%;">
        </iframe>
      </div>
    </div>
  </div>

  <section class="prov">
    <div class="prov-card">
      <div>
        <h2>Are you a CEU provider?</h2>
        <p>List your courses in front of thousands of medical coders actively searching for continuing education. Free basic listing. Premium options for more visibility.</p>
        <a href="mailto:providers@findmyceus.com" class="prov-btn">
          List your courses
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>
      <div class="perks">
        <div class="perk">
          <div class="perk-ico pi-g">&#x1F4CB;</div>
          <div><h4>Unlimited course listings</h4><p>Add every course, webinar, and workshop you offer</p></div>
        </div>
        <div class="perk">
          <div class="perk-ico pi-b">&#x1F4CA;</div>
          <div><h4>Track your reach</h4><p>See how many coders view and click through to register</p></div>
        </div>
        <div class="perk">
          <div class="perk-ico pi-a">&#x2B50;</div>
          <div><h4>Get featured</h4><p>Spotlight listings appear first in search and in our weekly email</p></div>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
