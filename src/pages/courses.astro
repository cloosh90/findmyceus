---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import CourseCard from '../components/CourseCard.astro';
import courses from '../data/courses.json';
---
<Layout title="Browse CEU Courses — FindMyCEUs" description="Browse all AAPC and AHIMA-approved CEU courses for medical coders. Filter by price, format, credential, level, and more.">
  <Nav currentPage="courses" />

  <!-- Page Hero / Search -->
  <div class="page-hero">
    <div class="page-hero-inner">
      <h1>Browse CEU Courses</h1>
      <div class="search-wrap">
        <svg class="search-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
        <input type="text" id="search-input" placeholder="Search courses, topics, or providers..." autocomplete="off">
      </div>
    </div>
  </div>

  <!-- Filter Bar -->
  <div class="filter-bar">
    <div class="filter-bar-inner">
      <span class="filter-group-label">Price</span>
      <span class="pill" data-filter="price" data-value="">All</span>
      <span class="pill" data-filter="price" data-value="free">Free</span>
      <span class="pill" data-filter="price" data-value="u50">Under $50</span>
      <span class="pill" data-filter="price" data-value="u100">Under $100</span>
      <span class="pill" data-filter="price" data-value="o100">$100+</span>

      <span class="filter-sep"></span>
      <span class="filter-group-label">Format</span>
      <span class="pill" data-filter="fmt" data-value="Self-study">Self-study</span>
      <span class="pill" data-filter="fmt" data-value="On-demand">On-demand</span>
      <span class="pill" data-filter="fmt" data-value="Live webinar">Live webinar</span>
      <span class="pill" data-filter="fmt" data-value="Live virtual">Live virtual</span>
      <span class="pill" data-filter="fmt" data-value="In-person">In-person</span>

      <span class="filter-sep"></span>
      <span class="filter-group-label">Credential</span>
      <span class="pill" data-filter="cred" data-value="CPC">CPC</span>
      <span class="pill" data-filter="cred" data-value="CCS">CCS</span>
      <span class="pill" data-filter="cred" data-value="CPMA">CPMA</span>
      <span class="pill" data-filter="cred" data-value="COC">COC</span>
      <span class="pill" data-filter="cred" data-value="CPB">CPB</span>
      <span class="pill" data-filter="cred" data-value="CPCO">CPCO</span>
      <span class="pill" data-filter="cred" data-value="CIRCC">CIRCC</span>
      <span class="pill" data-filter="cred" data-value="CRC">CRC</span>
      <span class="pill" data-filter="cred" data-value="CIC">CIC</span>
      <span class="pill" data-filter="cred" data-value="CMRS">CMRS</span>

      <span class="filter-sep"></span>
      <span class="filter-group-label">Level</span>
      <span class="pill" data-filter="level" data-value="Beginner">Beginner</span>
      <span class="pill" data-filter="level" data-value="Intermediate">Intermediate</span>
      <span class="pill" data-filter="level" data-value="Advanced">Advanced</span>

      <span class="filter-sep"></span>
      <span class="filter-group-label">CEUs</span>
      <span class="pill" data-filter="ceu" data-value="1">1+ CEU</span>
      <span class="pill" data-filter="ceu" data-value="2">2+ CEUs</span>
      <span class="pill" data-filter="ceu" data-value="3">3+ CEUs</span>
      <span class="pill" data-filter="ceu" data-value="5">5+ CEUs</span>

      <span class="filter-sep"></span>
      <span class="filter-group-label">Approved by</span>
      <span class="pill" data-filter="approved" data-value="AAPC">AAPC</span>
      <span class="pill" data-filter="approved" data-value="AHIMA">AHIMA</span>
    </div>
  </div>

  <!-- Results bar -->
  <div class="results-bar">
    <div class="results-count" id="results-count">
      Showing <strong id="visible-count">{courses.length}</strong> of <strong>{courses.length}</strong> courses
    </div>
    <div style="display:flex;gap:10px;align-items:center">
      <button class="btn-clear" id="btn-clear" style="display:none" type="button">&#x2715; Clear filters</button>
      <div class="sort-wrap">
        <span class="sort-label">Sort:</span>
        <select class="sort-select" id="sort-select">
          <option value="newest">Newest</option>
          <option value="price-asc">Price: Low to High</option>
          <option value="price-desc">Price: High to Low</option>
          <option value="ceus">Most CEUs</option>
        </select>
      </div>
    </div>
  </div>

  <!-- Course Grid — all cards rendered at build time -->
  <div class="courses-grid-wrap">
    <div class="grid" id="course-grid">
      {courses.map((course) => (
        <CourseCard course={course} />
      ))}
    </div>
    <div class="empty-state" id="empty-state" style="display:none;grid-column:1/-1">
      <span class="empty-icon">&#x1F50D;</span>
      <h3>No courses found</h3>
      <p>Try adjusting your search or filters to find what you're looking for.</p>
      <button class="btn-outline" id="btn-clear-empty" type="button">Clear all filters</button>
    </div>
  </div>

  <Footer />
</Layout>

<script>
  // ---- Filter state ----
  const state = {
    query: '',
    price: '',
    formats: [],
    credentials: [],
    levels: [],
    minCeus: '',
    approvedBy: [],
    sort: 'newest'
  };

  const totalCount = document.querySelectorAll('#course-grid .card').length;

  // ---- Read URL params on load ----
  (function applyUrlParams() {
    const p = new URLSearchParams(window.location.search);
    if (p.get('q'))       { state.query = p.get('q'); document.getElementById('search-input').value = p.get('q'); }
    if (p.get('price'))   state.price = p.get('price');
    if (p.get('fmt'))     state.formats = [p.get('fmt')];
    if (p.get('cred'))    state.credentials = [p.get('cred')];
    if (p.get('level'))   state.levels = [p.get('level')];
    if (p.get('approved')) state.approvedBy = [p.get('approved')];
    if (p.get('sort'))    state.sort = p.get('sort');
  })();

  // ---- Get all cards ----
  function getCards() {
    return Array.from(document.querySelectorAll('#course-grid .card'));
  }

  // ---- Match a card against current filters ----
  function cardMatches(card) {
    const priceRaw = card.dataset.price;                        // 'free' | '49' | '350' etc.
    const isFree = priceRaw === 'free';
    const priceNum = isFree ? 0 : parseFloat(priceRaw);
    const format = card.dataset.format;
    const credentials = card.dataset.credentials ? card.dataset.credentials.split(',') : [];
    const level = card.dataset.level;
    const ceus = parseFloat(card.dataset.ceus);
    const approved = card.dataset.approved ? card.dataset.approved.split(',') : [];
    const title = card.dataset.title || '';
    const provider = card.dataset.provider || '';
    const description = card.dataset.description || '';

    // Query match
    if (state.query) {
      const q = state.query.toLowerCase();
      if (!title.includes(q) && !provider.includes(q) && !description.includes(q)) return false;
    }

    // Price match
    if (state.price) {
      if (state.price === 'free' && !isFree) return false;
      if (state.price === 'u50'  && (isFree || priceNum >= 50))  return false;
      if (state.price === 'u100' && (isFree || priceNum >= 100)) return false;
      if (state.price === 'o100' && (isFree || priceNum < 100))  return false;
      if (state.price === 'paid' && isFree)                       return false;
    }

    // Format match (multi-select OR logic)
    if (state.formats.length > 0 && !state.formats.includes(format)) return false;

    // Credential match (multi-select OR logic)
    if (state.credentials.length > 0) {
      const hasMatch = state.credentials.some(c => credentials.includes(c));
      if (!hasMatch) return false;
    }

    // Level match (multi-select OR logic)
    if (state.levels.length > 0 && !state.levels.includes(level)) return false;

    // Min CEUs match
    if (state.minCeus && ceus < parseFloat(state.minCeus || '0')) return false;

    // Approved by match (multi-select OR logic)
    if (state.approvedBy.length > 0) {
      const hasMatch = state.approvedBy.some(a => approved.includes(a));
      if (!hasMatch) return false;
    }

    return true;
  }

  // ---- Sort cards ----
  function getNumericPrice(card) {
    const raw = card.dataset.price;
    return raw === 'free' ? 0 : (parseFloat(raw) || 0);
  }

  function sortCards(cards) {
    return cards.slice().sort((a, b) => {
      if (state.sort === 'price-asc') {
        return getNumericPrice(a) - getNumericPrice(b);
      }
      if (state.sort === 'price-desc') {
        return getNumericPrice(b) - getNumericPrice(a);
      }
      if (state.sort === 'ceus') {
        return parseFloat(b.dataset.ceus) - parseFloat(a.dataset.ceus);
      }
      // newest — sort by date descending
      return new Date(b.dataset.date).getTime() - new Date(a.dataset.date).getTime();
    });
  }

  // ---- Apply filters and sort ----
  function applyFilters() {
    const grid = document.getElementById('course-grid');
    const emptyState = document.getElementById('empty-state');
    const allCards = getCards();

    // Determine which cards match
    const matching = allCards.filter(cardMatches);
    const nonMatching = allCards.filter(c => !cardMatches(c));

    // Sort matching cards
    const sorted = sortCards(matching);

    // Hide non-matching
    nonMatching.forEach(c => { c.style.display = 'none'; });

    // Show and reorder matching
    sorted.forEach((c, i) => {
      c.style.display = '';
      grid.appendChild(c); // moves to end in sorted order
    });

    // Update count
    const visibleEl = document.getElementById('visible-count');
    if (visibleEl) visibleEl.textContent = String(matching.length);

    // Empty state
    if (matching.length === 0) {
      emptyState.style.display = 'block';
      grid.style.display = 'none';
    } else {
      emptyState.style.display = 'none';
      grid.style.display = '';
    }

    // Clear button
    const hasFilters = state.query || state.price || state.formats.length
      || state.credentials.length || state.levels.length
      || state.minCeus || state.approvedBy.length;
    document.getElementById('btn-clear').style.display = hasFilters ? '' : 'none';

    syncPillUI();
  }

  // ---- Sync pill active state ----
  function syncPillUI() {
    document.querySelectorAll('[data-filter]').forEach(pill => {
      const f = pill.dataset.filter;
      const v = pill.dataset.value;
      let isActive = false;
      if (f === 'price')    isActive = state.price === v && v !== '';
      if (f === 'fmt')      isActive = state.formats.includes(v);
      if (f === 'cred')     isActive = state.credentials.includes(v);
      if (f === 'level')    isActive = state.levels.includes(v);
      if (f === 'ceu')      isActive = state.minCeus === v;
      if (f === 'approved') isActive = state.approvedBy.includes(v);
      pill.classList.toggle('active', isActive);
    });
  }

  // ---- Clear all ----
  function clearFilters() {
    state.query = '';
    state.price = '';
    state.formats = [];
    state.credentials = [];
    state.levels = [];
    state.minCeus = '';
    state.approvedBy = [];
    const searchInput = document.getElementById('search-input');
    if (searchInput) searchInput.value = '';
    applyFilters();
  }

  // ---- Search input (debounced) ----
  let searchTimer;
  const searchInput = document.getElementById('search-input');
  if (searchInput) {
    searchInput.addEventListener('input', function() {
      clearTimeout(searchTimer);
      searchTimer = setTimeout(() => {
        state.query = this.value.trim();
        applyFilters();
      }, 220);
    });
  }

  // ---- Filter pills ----
  const filterBar = document.querySelector('.filter-bar-inner');
  if (filterBar) {
    filterBar.addEventListener('click', function(e) {
      const pill = e.target.closest('[data-filter]');
      if (!pill) return;
      const f = pill.dataset.filter;
      const v = pill.dataset.value;

      if (f === 'price') {
        // Single-select toggle (empty string = all)
        state.price = state.price === v ? '' : v;
      } else if (f === 'fmt') {
        const idx = state.formats.indexOf(v);
        if (idx === -1) state.formats.push(v); else state.formats.splice(idx, 1);
      } else if (f === 'cred') {
        const idx = state.credentials.indexOf(v);
        if (idx === -1) state.credentials.push(v); else state.credentials.splice(idx, 1);
      } else if (f === 'level') {
        const idx = state.levels.indexOf(v);
        if (idx === -1) state.levels.push(v); else state.levels.splice(idx, 1);
      } else if (f === 'ceu') {
        state.minCeus = state.minCeus === v ? '' : v;
      } else if (f === 'approved') {
        const idx = state.approvedBy.indexOf(v);
        if (idx === -1) state.approvedBy.push(v); else state.approvedBy.splice(idx, 1);
      }
      applyFilters();
    });
  }

  // ---- Sort ----
  const sortSelect = document.getElementById('sort-select');
  if (sortSelect) {
    sortSelect.addEventListener('change', function() {
      state.sort = this.value;
      applyFilters();
    });
  }

  // ---- Clear buttons ----
  const btnClear = document.getElementById('btn-clear');
  if (btnClear) btnClear.addEventListener('click', clearFilters);
  const btnClearEmpty = document.getElementById('btn-clear-empty');
  if (btnClearEmpty) btnClearEmpty.addEventListener('click', clearFilters);

  // ---- Initial apply (handles URL params) ----
  if (sortSelect && state.sort) sortSelect.value = state.sort;
  applyFilters();
</script>
